# =============================================================================
# JobNomad -- Variables d'environnement
# =============================================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# NE JAMAIS committer .env.local (gitignored).
#
# Convention de nommage Supabase :
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY = anciennement "anon key"
#   (Supabase a renomme la cle anonyme en "publishable key" fin 2024)
#   Les variables NEXT_PUBLIC_* sont exposees au navigateur -- n'y mettre
#   que des valeurs PUBLIQUES (URL + cle publishable).
# =============================================================================

# App -- URL publique du site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase -- Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Anciennement "anon key" -- visible dans le navigateur, sans danger
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase -- Project Settings > API > service_role
# SERVEUR UNIQUEMENT -- ne jamais exposer cote client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase -- Project ref (20 lettres minuscules, ex: abcdefghijklmnopqrst)
# Visible dans : Project Settings > General ou dans l'URL du dashboard
# Utilise uniquement par scripts/setup-supabase-smtp.ts (pas a l'execution de l'app)
SUPABASE_PROJECT_REF=<20-lowercase-letters>

# Supabase -- Personal access token pour la Management API
# Generer sur : https://supabase.com/dashboard/account/tokens
# SERVEUR UNIQUEMENT -- utilise uniquement par le script de setup SMTP, jamais en runtime app
# Ne pas mettre dans Vercel runtime env vars -- seulement local + GitHub Secret CI
SUPABASE_ACCESS_TOKEN=sbp_...

# Resend -- resend.com > API Keys
# Doit commencer par "re_"
# Obligatoire en production (Supabase Auth l'utilise pour envoyer les magic links)
# En dev local, laisser vide -- Supabase CLI utilise Inbucket a la place
RESEND_API_KEY=re_...

# Email expediteur -- identite pour tous les emails transactionnels
# EMAIL_FROM_ADDRESS doit etre sur un domaine verifie dans Resend
# En prod : auth@jobnomad.app | En dev local : laisser vide (Inbucket)
EMAIL_FROM_ADDRESS=auth@jobnomad.app
EMAIL_FROM_NAME=JobNomad

# Stripe -- Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google AI -- aistudio.google.com
GEMINI_API_KEY=AIza...

# OpenAI -- platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Vercel Cron -- doit correspondre a l'en-tete Authorization: Bearer <secret>
# Generer avec : openssl rand -hex 32
CRON_SECRET=<chaine-aleatoire-32-chars>

# Rate limiting -- pepper pour hasher les IPs (stocke en DB, jamais en clair)
# Generer avec : openssl rand -hex 16
RATE_LIMIT_PEPPER=<chaine-aleatoire-16-chars>
