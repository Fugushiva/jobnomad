# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — local secrets never committed
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PDFs
*.pdf

# Supabase local temp (contains project ref, pooler URL, org IDs — sensitive)
supabase/.temp/

# Supabase CLI local branch metadata
supabase/.branches/

# Playwright test artifacts (screenshots, videos, traces)
/test-results/
/playwright-report/
/playwright/.cache/

# Tool caches (local only)
.token-savior-cache.json
